vesselCapacity  = 2.0;
waterCapacity   = 1.0;
vesselDiameter  = 95;
nozzleDiameter  = 9;
rocketDryMass   = 0.20;
pressureGauge   = 6.0;
waterLossFactor = 0.20;
airLossFactor   = 0.30;
k = 1.40;
g = 9.81;
pa = 100000;
ro = 1000;
R  = 286.9;
temp = 293;

v_air = 1 ;
rho = 1.225 ;
S = .5 ; 
fi = deg2rad(90.0) ;
V_init = (vesselCapacity - waterCapacity) / 1000 ;
mA_init = (pressureGauge*1e5 + pa) / (R*temp) * V_init ;
m_init  = rocketDryMass + (waterCapacity/1000)*ro + mA_init ;
X0 =  [0; 0; 0; 0 ; rocket.V_init ; rocket.m_init] ;
AR = 5 ;
e = 0.8 ; 
cd0 = 0.04 ;

res = thrust(vesselCapacity, waterCapacity, vesselDiameter, nozzleDiameter, ...
           rocketDryMass, pressureGauge, waterLossFactor, ...
           airLossFactor, k, g, pa, ro, R, temp);

tT_log = res.time_log ;
T_log = res.T_log ;
m_log = res.m_log ;

data  = readmatrix('xfoil_polar.txt', 'NumHeaderLines', 12);
alpha = deg2rad(data(:, 1));
cl_data = data(:, 2);   
cd_data = data(:, 3);

h = .001 ;
t_max = 1000 ;
t_vec = 0:h:t_max ;
N = length(t_vec);
X_log = zeros(6, N) ;
X_log(:,1) = X0 ;

for  i = 1 : (N-1)
    t = t_vec(i) ;
    Xi = X_log(:,i) ;
    
    if i <= length(T_log)
        T = T_log(i);
        m = m_log(i) ;
    else 
        T = 0;
        m = m_log(end) ;
    end

    k1 = h * dynamics(t, Xi, alpha, cl_data, cd_data, rho, S, m, g, T, fi, v_air) ;
    k2 = h * dynamics(t + 0.5 * h, Xi + 0.5 * k1, alpha, cl_data, cd_data, rho, S, m, g, T, fi, v_air) ;
    k3 = h * dynamics(t + 0.5 * h, Xi + 0.5 * k2, alpha, cl_data, cd_data, rho, S, m, g, T, fi, v_air) ;
    k4 = h * dynamics(t + h, Xi + k3, alpha, cl_data, cd_data, rho, S, m, g, T, fi, v_air) ;

    X_log(:, i+1) = Xi + (1/6) * (k1 + 2 * k2 + 2* k3 + k4) ;

    if X_log(3, i+1) < 0 
        X_log = X_log(:, 1: i+1) ;
        t_vec = t_vec(1: i+1) ;
        break
    end
end

figure;
